var categoryLabels = {
    'general':'\u7EFC\u5408','technology':'\u79D1\u6280','finance':'\u91D1\u878D','telecom':'\u901A\u4FE1',
    'beverage':'\u996E\u54C1','food':'\u98DF\u54C1','airline':'\u822A\u7A7A','retail':'\u96F6\u552E',
    'fashion-luxury':'\u65F6\u5C1A\u5962\u4F88','beauty':'\u7F8E\u5986','sport':'\u4F53\u80B2','materials':'\u6750\u6599',
    'watch':'\u8155\u8868','automotive':'\u6C7D\u8F66','sportswear':'\u8FD0\u52A8\u670D\u9970','cosmetics':'\u5316\u5986\u54C1',
    'consumer-goods':'\u6D88\u8D39\u54C1','healthcare':'\u533B\u7597','media':'\u4F20\u5A92'
};

function renderBrands(lang) {
    var container = document.getElementById('brand-list');
    var html = '';
    var count = 0;
    for(var i = 0; i < brandsData.length; i++) {
        var b = brandsData[i];
        var nameDisplay = b.name;
        var catLabel = categoryLabels[b.category] || b.category;
        html += '<a href="/' + b.slug + '/" class="brand-card">' +
            '<h2>' + nameDisplay + '</h2>' +
            '<div class="en">' + b.name_en + '</div>' +
            '<span class="cat-tag">' + catLabel + '</span></a>';
        count++;
    }
    container.innerHTML = html;
}

function switchLang(lang) {
    var tabs = document.querySelectorAll('.lang-tab');
    for(var i = 0; i < tabs.length; i++) {
        tabs[i].classList.remove('active');
        if(tabs[i].getAttribute('onclick').indexOf(lang) > -1) {
            tabs[i].classList.add('active');
        }
    }
    renderBrands(lang);
}

function searchBrand() {
    var q = document.getElementById('search-input').value.toLowerCase().trim();
    var cards = document.querySelectorAll('.brand-card');
    for(var i = 0; i < cards.length; i++) {
        var card = cards[i];
        var text = card.textContent.toLowerCase();
        if(!q || text.includes(q)) {
            card.style.display = '';
        } else {
            card.style.display = 'none';
        }
    }
}

// 默认渲染
renderBrands('zh-CN');
</script>
</body>
</html>